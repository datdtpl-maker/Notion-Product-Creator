{
  "name": "notion-product-creator",
  "version": "1.2.9",
  "description": "App tự động hóa viết bài sản phẩm, tạo ảnh ChatGPT và cập nhật Notion",
  "main": "main.js",
  "bin": "server.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test test/*.test.js",
    "electron-build": "electron-builder build --win --x64 --publish never",
    "electron-build-mac": "electron-builder build --mac dmg --universal --publish never"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.0",
    "express": "^4.19.2",
    "openai": "^4.52.7",
    "playwright": "^1.45.0"
  },
  "pkg": {
    "assets": [
      "node_modules/playwright-core/browsers.json"
    ]
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.khaihoan.notionproductcreator",
    "productName": "Notion Product Creator",
    "publish": null,
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "afterSign": "scripts/notarize.js",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Notion Product Creator"
    },
    "files": [
      "main.js",
      "server.js",
      "lib/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ]
  }
}
